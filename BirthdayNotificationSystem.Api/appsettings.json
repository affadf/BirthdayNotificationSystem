{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=BirthdayNotificationSystem;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "EmailService": {
    "BaseUrl": "https://email-service.digitalenvision.com.au",
    "SendMailPath": "/api/v1/send-mail",
    "ApiKey": "",
    "FromEmail": "birthdays@example.com",
    "BirthdaySubject": "Happy birthday",
    "AnniversarySubject": "Happy anniversary",
    "DefaultSubject": "Notification",
    "TimeoutSeconds": 10
  },
  "NotificationWorker": {
    "Enabled": true,
    "BatchSize": 100,
    "PollingIntervalSeconds": 30,
    "LockTimeoutMinutes": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
